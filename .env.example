# Turso Database (required for leaderboard, config, etc.)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_auth_token

# The min_tracker_balance for the snake game is stored in the Turso `config` table
# Update it there — no env var needed.
# INSERT OR REPLACE INTO config (key, value) VALUES ('min_tracker_balance', '100000');

# Resend (transactional email — domain seekertracker.com)
RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Seeker Tracker <noreply@seekertracker.com>

# Notify when publishers save /apps/manage form
DAPP_UPDATE_NOTIFY_EMAIL=seeker@milysec.com
