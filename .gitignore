# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

####################################
# Editors / IDEs
####################################
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.idea/
*.iml

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

yarn.lock

package-lock.json
# Cloudflare Workers / OpenNext build (accidentally added)
.open-next/
.dev.vars
.wrangler/

# Large binaries excluded from CF Workers assets (25MB limit)
_cf_exclude/
public/**/*.apk
public/snake/snake.apk
public/seekertracker.apk
